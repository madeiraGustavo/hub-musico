# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/hub_musico

# JWT — gerar com: openssl rand -base64 64
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Storage (S3 ou compatível)
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# App
PORT=3001
NODE_ENV=development
