# Supabase — copie do painel: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nunca exposta ao browser — apenas em Route Handlers server-side
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket (criado no painel do Supabase)
SUPABASE_STORAGE_BUCKET=media-assets
