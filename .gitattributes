# Força LF em todos os arquivos de texto — evita CRLF no Windows
* text=auto eol=lf

# Arquivos que devem ser sempre LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.env*  text eol=lf

# Binários — sem conversão
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
